app-id: io.github.deenbee.oaplayer
runtime: org.freedesktop.Platform
runtime-version: '25.08'
sdk: org.freedesktop.Sdk
command: oa-player-wrapper
separate-locales: false

tags:
  - proprietary

finish-args:
  - --share=ipc
  - --share=network
  - --socket=x11
  - --socket=wayland
  - --socket=pulseaudio
  - --device=dri
  - --filesystem=home
  - --talk-name=org.freedesktop.Notifications

modules:
  - name: oa-player
    buildsystem: simple
    build-commands:
      - ar x oa-player.deb
      - tar xf data.tar.xz
      - cp -r usr/* /app/
      - cp -r opt /app/
      - mkdir -p /app/bin
      - ln -s /app/opt/OA\ Player/oa-player /app/bin/oa-player
      - type: script
        dest-filename: oa-player-wrapper
        commands:
          - exec /app/opt/OA\ Player/oa-player --no-sandbox "$@"     
      - mkdir -p /app/share/icons/hicolor/512x512/apps
      - install -Dm644 io.github.deenbee.oaplayer.png /app/share/icons/hicolor/512x512/apps/io.github.deenbee.oaplayer.png
      - install -Dm644 io.github.deenbee.oaplayer.desktop /app/share/applications/io.github.deenbee.oaplayer.desktop
      - install -Dm644 io.github.deenbee.oaplayer.metainfo.xml /app/share/metainfo/io.github.deenbee.oaplayer.metainfo.xml
    sources:
      - type: file
        url: https://github.com/deenbee/oa-player-flatpak/releases/download/audio/oa-player_0.5.9_amd64.deb
        sha256: 8c2933b1e0e9e588a54dc75f05da88cbd7bc5230711baf988c304cc060c91241
        arch: x86_64
        dest-filename: oa-player.deb
      - type: file
        url: https://github.com/deenbee/oa-player-flatpak/releases/download/audio/oa-player_0.5.9_arm64.deb
        sha256: cf983ed2db594d704f55bc25bf3a66e84738329113a43c42eea2aa9997737c92
        arch: aarch64
        dest-filename: oa-player.deb
      - type: file
        url: https://raw.githubusercontent.com/deenbee/oa-player-flatpak/main/io.github.deenbee.oaplayer.png
        sha256: b0609e5b4e9296c3bf7ba32bc128170d8cea7c9f78ae08663f7aeb087b1d28f0
        dest-filename: io.github.deenbee.oaplayer.png
      - type: file
        url: https://raw.githubusercontent.com/deenbee/oa-player-flatpak/main/io.github.deenbee.oaplayer.desktop
        sha256: 8fab2eb55fda78367e982db4b6d0c9e36b660aea9817565d63e576e939050d14
        dest-filename: io.github.deenbee.oaplayer.desktop
      - type: file
        url: https://raw.githubusercontent.com/deenbee/oa-player-flatpak/main/io.github.deenbee.oaplayer.metainfo.xml
        sha256: 7195379f121dd6c3acb60458cacc97c4a738a9fe4aab7f53014761067cf8ff01
        dest-filename: io.github.deenbee.oaplayer.metainfo.xml
